<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#1E1E2E" android:padding="16dp">
    <EditText android:id="@+id/et_search_clipboard"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Search clipboard..." android:textColor="#E0E0E0"
        android:textColorHint="#A0A0C0" android:backgroundTint="#7C3AED"
        android:layout_marginBottom="8dp" />
    <ImageButton android:id="@+id/btn_clear_all"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:src="@drawable/ic_delete" android:contentDescription="Clear All"
        android:layout_gravity="end" android:layout_marginBottom="8dp" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_clipboard" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" />
</LinearLayout>
