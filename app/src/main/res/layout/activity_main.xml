<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LiyoBoard"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="by Death Legion Team"
            android:textColor="#7C3AED"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Setup Status -->
        <LinearLayout
            android:id="@+id/card_setup_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2D2D44"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_setup_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 1: Enable LiyoBoard"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_setup_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable the keyboard in system settings"
                android:textColor="#A0A0C0"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btn_setup_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable Keyboard"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Quick Settings -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Settings"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2D2D44"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <Switch
                android:id="@+id/switch_haptic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Haptic Feedback"
                android:textColor="#E0E0E0"
                android:padding="8dp" />

            <Switch
                android:id="@+id/switch_sound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sound Feedback"
                android:textColor="#E0E0E0"
                android:padding="8dp" />

            <Switch
                android:id="@+id/switch_clipboard_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clipboard History"
                android:textColor="#E0E0E0"
                android:padding="8dp" />

            <Switch
                android:id="@+id/switch_auto_cap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-capitalization"
                android:textColor="#E0E0E0"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Features Grid -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Features"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:useDefaultMargins="true">

            <LinearLayout android:id="@+id/nav_themes"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:orientation="vertical"
                android:gravity="center" android:background="#2D2D44" android:padding="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_palette" android:contentDescription="Themes" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Themes" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="15 built-in" android:textColor="#A0A0C0" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_fonts"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:orientation="vertical"
                android:gravity="center" android:background="#2D2D44" android:padding="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_fonts" android:contentDescription="Fonts" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fonts" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="500+ fonts" android:textColor="#A0A0C0" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_clipboard"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:orientation="vertical"
                android:gravity="center" android:background="#2D2D44" android:padding="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_clipboard" android:contentDescription="Clipboard" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Clipboard" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="History &amp; Pin" android:textColor="#A0A0C0" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_extensions"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:orientation="vertical"
                android:gravity="center" android:background="#2D2D44" android:padding="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_extension" android:contentDescription="Extensions" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Extensions" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add-on Store" android:textColor="#A0A0C0" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_advanced"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:orientation="vertical"
                android:gravity="center" android:background="#2D2D44" android:padding="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_settings" android:contentDescription="Settings" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Settings" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Advanced" android:textColor="#A0A0C0" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_about"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:orientation="vertical"
                android:gravity="center" android:background="#2D2D44" android:padding="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_info" android:contentDescription="About" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="About" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="v1.0.0-beta1" android:textColor="#A0A0C0" android:textSize="12sp" />
            </LinearLayout>
        </GridLayout>

        <!-- Privacy Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A3A1A"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_shield"
                android:contentDescription="Privacy" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy Protected"
                    android:textColor="#2ECC71"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No internet permission. Zero data collection."
                    android:textColor="#90EE90"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
