<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1E1E2E">

    <ImageView
        android:id="@+id/iv_onboarding_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:contentDescription="Icon"
        android:tint="#7C3AED" />

    <TextView
        android:id="@+id/tv_onboarding_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tv_onboarding_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#7C3AED"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_onboarding_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A0A0C0"
        android:textSize="16sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="16dp" />

</LinearLayout>
