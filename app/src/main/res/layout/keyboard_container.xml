<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E2E"
    android:padding="4dp">

    <!-- Suggestion Bar -->
    <LinearLayout
        android:id="@+id/suggestion_bar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#1A1A2E"
        android:visibility="gone">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B0B0D0"
            android:textSize="14sp"
            android:gravity="center"
            android:text="" />
    </LinearLayout>

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="#1A1A2E">

        <ImageButton
            android:id="@+id/btn_clipboard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_clipboard"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clipboard"
            android:tint="#A0A0C0"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btn_emoji"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_emoji"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Emoji"
            android:tint="#A0A0C0"
            android:padding="8dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_theme"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_palette"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Theme"
            android:tint="#7C3AED"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:tint="#A0A0C0"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Keyboard Layout (Flexbox for key rows) -->
    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/keyboard_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:flexDirection="column"
        android:padding="4dp" />

</LinearLayout>
