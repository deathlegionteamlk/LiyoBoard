<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#2D2D44" android:padding="12dp"
    android:layout_margin="4dp">

    <ImageView android:id="@+id/iv_ext_preview"
        android:layout_width="match_parent" android:layout_height="80dp"
        android:scaleType="centerCrop" android:background="#3D3D5C"
        android:contentDescription="Preview" />
    <TextView android:id="@+id/tv_ext_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginTop="8dp" />
    <TextView android:id="@+id/tv_ext_author"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#A0A0C0" android:textSize="12sp" />
    <TextView android:id="@+id/tv_ext_type"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#7C3AED" android:textSize="11sp" android:layout_marginTop="4dp" />
</LinearLayout>
